{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Main Dashboard (index.html)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Dashboard Standalone (InfiniateDashboard.html)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3001", "."],
      "port": 3001
    }
  ]
}
