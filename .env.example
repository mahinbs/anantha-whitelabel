VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ChartMate Options API (FastAPI) — full E2E: frontend → this URL → OpenAlgo → broker.
# Example production: https://options-api.yourdomain.com  (no trailing slash)
# Leave unset to use Supabase Edge Functions for option chain / expiry / orders (if deployed).
# VITE_OPTIONS_API_URL=

# -----------------------------------------------------------------------------
# Supabase Edge Function secrets — set in the Supabase project, NOT in this file.
# Dashboard: Project Settings → Edge Functions → Secrets
# CLI:        supabase secrets set NAME=value
#
# Stripe keys and price IDs below must be added there for deployed functions.
# Do not put STRIPE_* in Vite (.env) unless you have a local-only workflow; the
# browser never needs STRIPE_SECRET_KEY or STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID.
# -----------------------------------------------------------------------------

# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Customer Portal configuration (bpc_...) — set as a Supabase secret so production
# uses the correct Stripe mode (live bpc vs test bpc). Example:
#   supabase secrets set STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=bpc_1TIRfmSQFpbfNakVFN0mQ3gN
# If unset, create-customer-portal-session falls back to a built-in default bpc_ id.
# STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=bpc_...
#
# New monthly plans (checkout / webhooks)
# STRIPE_PRICE_STARTER=price_...       → plan_id starterPlan ($49/mo)
# STRIPE_PRICE_GROWTH=price_...         → plan_id growthPlan ($99/mo)
# STRIPE_PRICE_PROFESSIONAL=price_...   → plan_id professionalPlan ($199/mo)
#
# Legacy Stripe price IDs — keep set while existing subscriptions still use these prices
# STRIPE_PRICE_BOT=price_...            → botIntegration
# STRIPE_PRICE_PROB=price_...           → probIntelligence
# STRIPE_PRICE_PRO=price_...            → proPlan
#
# White-label (unchanged)
# STRIPE_PRICE_WL_1Y=price_...
# STRIPE_PRICE_WL_2Y=price_...
# STRIPE_PRICE_WL_5Y=price_...
#
# Optional test checkout
# STRIPE_PRICE_TEST_1R=price_...
